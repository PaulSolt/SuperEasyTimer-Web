---
/**
 * The interactive web timer island.
 * Static markup (pill, input, controls) ships in the HTML for SEO; the
 * timer logic in the <script> hydrates in the browser. Reused on `/timer`
 * and `/presentation-timer`. Multiple instances per page are supported.
 */
interface Props {
  /** Starting minutes shown before the user types anything. */
  initialMinutes?: number;
  /** Show the fullscreen toggle (uses the browser Fullscreen API). */
  showFullscreen?: boolean;
  /** Visual size. 'hero' is the demo, 'full' is the standalone tool. */
  size?: 'hero' | 'full';
  /** Horizontal alignment of the pill, input, and controls. */
  align?: 'center' | 'start';
}

const { initialMinutes = 5, showFullscreen = true, size = 'hero', align = 'center' } =
  Astro.props;

const initialSeconds = Math.round(initialMinutes * 60);
const mm = String(Math.floor(initialSeconds / 60)).padStart(2, '0');
const ss = String(initialSeconds % 60).padStart(2, '0');
---

<div
  class:list={['set-timer', `set-timer--${size}`, `set-timer--align-${align}`]}
  data-set-timer
  data-theme="blue"
  data-initial-seconds={initialSeconds}
>
  <div class="timer-pill" data-pill>
    <span class="timer-digits" data-digits aria-live="polite">{mm}:{ss}</span>
  </div>

  <form class="timer-input-row" data-form>
    <input
      type="text"
      class="timer-input"
      data-input
      inputmode="text"
      autocomplete="off"
      spellcheck="false"
      placeholder="Type a time, like 5 min"
      aria-label="Set timer time"
    />
    <button type="submit" class="sr-only">Set timer</button>
  </form>

  <div class="timer-controls" role="group" aria-label="Timer controls">
    <button type="button" class="ctrl" data-toggle aria-label="Play or pause">
      <svg class="ic ic-play" viewBox="0 0 24 24" aria-hidden="true"><path d="M8 5v14l11-7z" /></svg>
      <svg class="ic ic-pause" viewBox="0 0 24 24" aria-hidden="true"><path d="M6 5h4v14H6zM14 5h4v14h-4z" /></svg>
      <span data-toggle-label>Start</span>
    </button>
    <button type="button" class="ctrl" data-reset aria-label="Reset timer">
      <svg class="ic" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 5V2L7 7l5 5V8a5 5 0 1 1-5 5H5a7 7 0 1 0 7-7z" /></svg>
      <span>Reset</span>
    </button>
    {
      showFullscreen && (
        <button type="button" class="ctrl" data-fullscreen aria-label="Toggle full screen">
          <svg class="ic" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M4 9V4h5v2H6v3H4zm11-5h5v5h-2V6h-3V4zM4 15h2v3h3v2H4v-5zm14 0h2v5h-5v-2h3v-3z" />
          </svg>
          <span data-fs-label>Full screen</span>
        </button>
      )
    }
  </div>

  <div class="timer-themes" role="group" aria-label="Timer theme">
    <span class="timer-themes-label">Theme</span>
    <button type="button" class="swatch swatch--blue" data-theme-btn="blue" aria-label="Blue theme" aria-pressed="true"></button>
    <button type="button" class="swatch swatch--black" data-theme-btn="black" aria-label="Black theme" aria-pressed="false"></button>
  </div>
</div>

<style>
  .set-timer {
    --pill-bg: var(--blue);
    --pill-glow: var(--glow-blue);
    --digit-color: var(--digits);

    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    width: 100%;
  }
  .set-timer--align-start {
    align-items: flex-start;
  }
  .set-timer[data-theme='black'] {
    --pill-bg: #000;
    --pill-glow: 0 8px 40px rgba(0, 0, 0, 0.55);
    --digit-color: #ffffff;
  }

  /* The pill is a display element: not clickable. */
  .timer-pill {
    display: flex;
    align-items: center;
    justify-content: center;
    width: min(100%, 460px);
    padding: clamp(1.5rem, 5vw, 2.75rem) 2rem;
    background: var(--pill-bg);
    border-radius: var(--radius-pill);
    box-shadow: var(--pill-glow);
    transition: background 0.2s ease;
    color: var(--digit-color);
  }
  .set-timer--full .timer-pill {
    width: min(100%, 560px);
  }

  .timer-digits {
    font-family: var(--font-digits);
    font-weight: 800;
    font-variant-numeric: tabular-nums;
    font-size: clamp(3.5rem, 14vw, 6.5rem);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--digit-color);
  }
  .set-timer--full .timer-digits {
    font-size: clamp(4rem, 18vw, 8rem);
  }

  /* Finished flash: pulse to red, then back to the theme color. */
  .set-timer.is-finished .timer-pill {
    animation: timer-flash 0.6s ease-in-out 6;
  }
  @keyframes timer-flash {
    0%,
    100% {
      background: var(--pill-bg);
    }
    50% {
      background: #ff453a;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .set-timer.is-finished .timer-pill {
      animation: none;
      background: #ff453a;
    }
  }

  .timer-input-row {
    width: min(100%, 460px);
  }
  .timer-input {
    width: 100%;
    padding: 0.875rem 1.125rem;
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--text);
    background: var(--bg-elevated);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    text-align: left;
  }
  .timer-input::placeholder {
    color: var(--text-faint);
  }
  .timer-input:focus {
    outline: none;
    border-color: var(--blue);
    box-shadow: 0 0 0 3px rgba(10, 132, 255, 0.25);
  }

  .timer-controls {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }
  .set-timer--align-start .timer-controls,
  .set-timer--align-start .timer-themes {
    justify-content: flex-start;
  }
  .ctrl {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.9rem;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    font-weight: 500;
    color: var(--text-muted);
    background: var(--bg-elevated);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    cursor: pointer;
    transition: color 0.15s ease, background 0.15s ease;
  }
  .ctrl:hover {
    color: var(--text);
    background: var(--bg-elevated-2);
  }
  .ic {
    width: 16px;
    height: 16px;
    fill: currentColor;
    flex: none;
  }
  /* Play/pause icon swap. */
  .ic-pause {
    display: none;
  }
  .set-timer.is-running .ic-play {
    display: none;
  }
  .set-timer.is-running .ic-pause {
    display: inline-block;
  }

  /* Theme swatches. */
  .timer-themes {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .timer-themes-label {
    font-size: 0.8125rem;
    color: var(--text-faint);
  }
  .swatch {
    width: 24px;
    height: 24px;
    padding: 0;
    border-radius: 50%;
    border: 2px solid var(--border-strong);
    cursor: pointer;
  }
  .swatch--blue {
    background: var(--blue);
  }
  .swatch--black {
    background: #000;
  }
  .swatch[aria-pressed='true'] {
    outline: 2px solid var(--text);
    outline-offset: 2px;
    border-color: transparent;
  }

  /* ---- Fullscreen view -----------------------------------------------
     Edge-to-edge countdown on the current theme color. Digits auto-fit by
     JS. Controls float over the screen and reveal on mouse movement. */
  .set-timer.is-fullscreen {
    justify-content: center;
    gap: 0;
    padding: 0;
    width: 100vw;
    height: 100vh;
    background: var(--pill-bg);
  }
  .set-timer.is-fullscreen .timer-input-row,
  .set-timer.is-fullscreen .timer-themes {
    display: none;
  }
  .set-timer.is-fullscreen .timer-controls {
    position: fixed;
    bottom: clamp(1.5rem, 5vh, 3rem);
    left: 50%;
    transform: translateX(-50%);
    z-index: 20;
    padding: 0.5rem;
    border-radius: var(--radius-pill);
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: opacity 0.25s ease;
  }
  .set-timer.is-fullscreen.is-idle {
    cursor: none;
  }
  .set-timer.is-fullscreen.is-idle .timer-controls {
    opacity: 0;
    pointer-events: none;
  }
  .set-timer.is-fullscreen .timer-pill {
    width: 100%;
    height: 100%;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
  }
  .set-timer.is-fullscreen.is-finished .timer-pill {
    animation: timer-flash-full 0.6s ease-in-out 6;
  }
  @keyframes timer-flash-full {
    0%,
    100% {
      background: transparent;
    }
    50% {
      background: #ff453a;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .set-timer.is-fullscreen.is-finished .timer-pill {
      animation: none;
      background: #ff453a;
    }
  }
</style>

<script>
  type ParseResult = { op: 'set' | 'add'; seconds: number };

  const THEME_KEY = 'set-timer-theme';

  function parseDuration(raw: string): number | null {
    const input = raw.trim().toLowerCase();
    if (!input) return null;

    // mm:ss or hh:mm:ss duration (NOT a time of day).
    if (input.includes(':')) {
      const parts = input.split(':').map((p) => parseInt(p, 10));
      if (parts.some((n) => Number.isNaN(n))) return null;
      let secs = 0;
      for (const p of parts) secs = secs * 60 + p;
      return secs > 0 ? secs : null;
    }

    // A bare number means minutes (matches the app).
    let total = 0;
    let matched = false;
    const re = /(\d+(?:\.\d+)?)\s*(h(?:ours?|rs?)?|m(?:in(?:ute)?s?)?|s(?:ec(?:ond)?s?)?)?/g;
    let m: RegExpExecArray | null;
    while ((m = re.exec(input)) !== null) {
      const value = parseFloat(m[1]);
      if (Number.isNaN(value)) continue;
      const unit = m[2] || '';
      matched = true;
      if (unit.startsWith('h')) total += value * 3600;
      else if (unit.startsWith('s')) total += value;
      else total += value * 60;
    }
    if (!matched) return null;
    const secs = Math.round(total);
    return secs > 0 ? secs : null;
  }

  // Clock time, only with an explicit am/pm (avoids mm:ss ambiguity).
  function parseClock(raw: string): number | null {
    const m = raw.trim().toLowerCase().match(/^(\d{1,2})(?::(\d{2}))?\s*(am|pm)$/);
    if (!m) return null;
    let h = parseInt(m[1], 10);
    const min = m[2] ? parseInt(m[2], 10) : 0;
    const ap = m[3];
    if (h < 1 || h > 12 || min > 59) return null;
    if (ap === 'pm' && h !== 12) h += 12;
    if (ap === 'am' && h === 12) h = 0;
    const now = new Date();
    const target = new Date(now);
    target.setHours(h, min, 0, 0);
    if (target.getTime() <= now.getTime()) target.setDate(target.getDate() + 1);
    return Math.round((target.getTime() - now.getTime()) / 1000);
  }

  function parseInput(raw: string): ParseResult | null {
    const s = raw.trim().toLowerCase();
    if (!s) return null;

    let m = s.match(/^(?:add|\+)\s*(.+)$/);
    if (m) {
      const d = parseDuration(m[1]);
      return d == null ? null : { op: 'add', seconds: d };
    }
    m = s.match(/^(?:remove|subtract|minus|-)\s*(.+)$/);
    if (m) {
      const d = parseDuration(m[1]);
      return d == null ? null : { op: 'add', seconds: -d };
    }

    const clock = parseClock(s);
    if (clock != null) return { op: 'set', seconds: clock };

    const d = parseDuration(s);
    return d == null ? null : { op: 'set', seconds: d };
  }

  function formatTime(totalSeconds: number): string {
    const s = Math.max(0, Math.round(totalSeconds));
    const h = Math.floor(s / 3600);
    const m = Math.floor((s % 3600) / 60);
    const sec = s % 60;
    const pad = (n: number) => String(n).padStart(2, '0');
    return h > 0 ? `${h}:${pad(m)}:${pad(sec)}` : `${pad(m)}:${pad(sec)}`;
  }

  class SetTimer {
    root: HTMLElement;
    digitsEl: HTMLElement;
    toggleLabel: HTMLElement;
    input: HTMLInputElement;
    form: HTMLFormElement;
    fsButton: HTMLElement | null = null;
    fsLabel: HTMLElement | null = null;

    initialSeconds: number;
    remaining: number;
    running = false;
    endsAt = 0;
    rafId = 0;
    lastLen = 0;
    idleTimer = 0;
    audioCtx: AudioContext | null = null;

    constructor(root: HTMLElement) {
      this.root = root;
      this.digitsEl = root.querySelector('[data-digits]')!;
      this.toggleLabel = root.querySelector('[data-toggle-label]')!;
      this.input = root.querySelector('[data-input]')!;
      this.form = root.querySelector('[data-form]')!;

      this.initialSeconds = Number(root.dataset.initialSeconds) || 300;
      this.remaining = this.initialSeconds;

      this.bind();
      this.initTheme();
      this.render();
    }

    bind() {
      this.form.addEventListener('submit', (e) => {
        e.preventDefault();
        this.applyInput();
      });

      this.root.querySelector('[data-toggle]')?.addEventListener('click', () => this.toggle());
      this.root.querySelector('[data-reset]')?.addEventListener('click', () => this.reset());

      this.fsButton = this.root.querySelector('[data-fullscreen]');
      this.fsLabel = this.root.querySelector('[data-fs-label]');
      this.fsButton?.addEventListener('click', () => this.toggleFullscreen());

      this.root.querySelectorAll<HTMLElement>('[data-theme-btn]').forEach((btn) => {
        btn.addEventListener('click', () => this.setTheme(btn.dataset.themeBtn || 'blue'));
      });

      document.addEventListener('fullscreenchange', () => this.onFullscreenChange());
      window.addEventListener('resize', () => this.fit());
      document.addEventListener('mousemove', this.handleActivity);
      document.addEventListener('keydown', this.handleActivity);
      document.addEventListener('touchstart', this.handleActivity);
    }

    handleActivity = () => {
      if (!this.isFullscreen()) return;
      this.root.classList.remove('is-idle');
      clearTimeout(this.idleTimer);
      this.idleTimer = window.setTimeout(() => {
        if (this.isFullscreen()) this.root.classList.add('is-idle');
      }, 2500);
    };

    applyInput() {
      const result = parseInput(this.input.value);
      if (!result) {
        this.input.classList.add('shake');
        setTimeout(() => this.input.classList.remove('shake'), 400);
        return;
      }
      this.input.value = '';
      this.input.blur();
      if (result.op === 'add') {
        this.addSeconds(result.seconds);
        return;
      }
      this.initialSeconds = result.seconds;
      this.remaining = result.seconds;
      this.start();
    }

    addSeconds(delta: number) {
      this.remaining = Math.max(0, this.remaining + delta);
      this.initialSeconds = Math.max(1, this.initialSeconds + delta);
      if (this.running) this.endsAt = performance.now() + this.remaining * 1000;
      if (this.running && this.remaining <= 0) {
        this.finish();
        return;
      }
      this.render();
    }

    toggle() {
      this.ensureAudio(); // first interaction unlocks audio
      this.running ? this.pause() : this.start();
    }

    start() {
      if (this.remaining <= 0) this.remaining = this.initialSeconds;
      this.root.classList.remove('is-finished');
      this.root.classList.add('is-running');
      this.running = true;
      this.endsAt = performance.now() + this.remaining * 1000;
      this.toggleLabel.textContent = 'Pause';
      this.tick();
    }

    pause() {
      this.running = false;
      this.root.classList.remove('is-running');
      cancelAnimationFrame(this.rafId);
      this.toggleLabel.textContent = 'Start';
    }

    reset() {
      this.running = false;
      this.root.classList.remove('is-running');
      cancelAnimationFrame(this.rafId);
      this.remaining = this.initialSeconds;
      this.root.classList.remove('is-finished');
      this.toggleLabel.textContent = 'Start';
      this.render();
    }

    tick = () => {
      if (!this.running) return;
      this.remaining = (this.endsAt - performance.now()) / 1000;
      if (this.remaining <= 0) {
        this.remaining = 0;
        this.render();
        this.finish();
        return;
      }
      this.render();
      this.rafId = requestAnimationFrame(this.tick);
    };

    finish() {
      this.running = false;
      this.root.classList.remove('is-running');
      this.root.classList.add('is-finished');
      this.toggleLabel.textContent = 'Start';
      this.beep();
    }

    render() {
      const text = formatTime(this.remaining);
      this.digitsEl.textContent = text;
      if (this.isFullscreen() && text.length !== this.lastLen) this.fit();
    }

    // ---- Theme ----------------------------------------------------------
    initTheme() {
      let theme = 'blue';
      try {
        const stored = localStorage.getItem(THEME_KEY);
        if (stored === 'blue' || stored === 'black') theme = stored;
      } catch {
        /* localStorage unavailable */
      }
      this.setTheme(theme, false);
    }

    setTheme(theme: string, persist = true) {
      this.root.dataset.theme = theme;
      this.root.querySelectorAll<HTMLElement>('[data-theme-btn]').forEach((btn) => {
        btn.setAttribute('aria-pressed', String(btn.dataset.themeBtn === theme));
      });
      if (persist) {
        try {
          localStorage.setItem(THEME_KEY, theme);
        } catch {
          /* ignore */
        }
      }
      if (this.isFullscreen()) this.fit();
    }

    // ---- Fullscreen -----------------------------------------------------
    isFullscreen() {
      return document.fullscreenElement === this.root;
    }

    onFullscreenChange() {
      const active = this.isFullscreen();
      this.root.classList.toggle('is-fullscreen', active);
      if (this.fsLabel) this.fsLabel.textContent = active ? 'Exit full screen' : 'Full screen';
      if (active) {
        this.fit();
        this.handleActivity();
      } else {
        this.digitsEl.style.fontSize = '';
        this.lastLen = 0;
        this.root.classList.remove('is-idle');
        clearTimeout(this.idleTimer);
      }
    }

    fit() {
      if (!this.isFullscreen()) return;
      const availW = this.root.clientWidth * 0.9;
      const availH = this.root.clientHeight * 0.8;
      const base = 100;
      this.digitsEl.style.fontSize = `${base}px`;
      const rect = this.digitsEl.getBoundingClientRect();
      if (rect.width === 0 || rect.height === 0) return;
      const scale = Math.min(availW / rect.width, availH / rect.height);
      this.digitsEl.style.fontSize = `${Math.floor(base * scale)}px`;
      this.lastLen = (this.digitsEl.textContent || '').length;
    }

    toggleFullscreen() {
      if (document.fullscreenElement) {
        document.exitFullscreen();
      } else {
        this.root.requestFullscreen?.();
      }
    }

    // ---- Audio ----------------------------------------------------------
    ensureAudio() {
      if (this.audioCtx) return;
      try {
        const AC =
          window.AudioContext ||
          (window as unknown as { webkitAudioContext: typeof AudioContext }).webkitAudioContext;
        this.audioCtx = new AC();
      } catch {
        this.audioCtx = null;
      }
    }

    beep() {
      const ctx = this.audioCtx;
      if (!ctx) return;
      const now = ctx.currentTime;
      for (let i = 0; i < 3; i++) {
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.type = 'sine';
        osc.frequency.value = 880;
        const t = now + i * 0.4;
        gain.gain.setValueAtTime(0, t);
        gain.gain.linearRampToValueAtTime(0.25, t + 0.02);
        gain.gain.exponentialRampToValueAtTime(0.0001, t + 0.3);
        osc.connect(gain).connect(ctx.destination);
        osc.start(t);
        osc.stop(t + 0.32);
      }
    }
  }

  document.querySelectorAll<HTMLElement>('[data-set-timer]').forEach((el) => {
    new SetTimer(el);
  });
</script>

<style is:global>
  .timer-input.shake {
    animation: timer-shake 0.4s ease;
    border-color: #ff453a;
  }
  @keyframes timer-shake {
    0%,
    100% {
      transform: translateX(0);
    }
    25% {
      transform: translateX(-6px);
    }
    75% {
      transform: translateX(6px);
    }
  }
</style>
