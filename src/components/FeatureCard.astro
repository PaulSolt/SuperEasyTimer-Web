---
interface Props {
  title: string;
  /** Optional emoji/glyph stand-in. TODO: swap for real icons. */
  icon?: string;
}
const { title, icon } = Astro.props;
---

<article class="card feature-card">
  {icon && <span class="feature-icon" aria-hidden="true">{icon}</span>}
  <h3 class="feature-title">{title}</h3>
  <p class="feature-body"><slot /></p>
</article>

<style>
  .feature-card {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    height: 100%;
  }
  .feature-icon {
    font-size: 1.5rem;
    line-height: 1;
  }
  .feature-title {
    font-size: 1.0625rem;
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.01em;
  }
  .feature-body {
    font-size: 0.9375rem;
    margin: 0;
  }
</style>
