---
import { site } from '../config/site';

const links = [
  { href: '/timer', label: 'Web Timer' },
  { href: '/presentation-timer', label: 'Presentation Timer' },
  { href: '/blog', label: 'Blog' },
  { href: '/download', label: 'Download' },
];

const pathname = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? pathname === '/' : pathname.startsWith(href);
---

<header class="site-header">
  <div class="container header-inner">
    <a href="/" class="brand" aria-label={`${site.name} home`}>
      <img class="brand-mark" src="/icon.png" alt="" width="26" height="26" aria-hidden="true" />
      <span class="brand-name">{site.name}</span>
    </a>

    <nav aria-label="Primary">
      <ul class="nav-list">
        {
          links.map((link) => (
            <li>
              <a
                href={link.href}
                class:list={['nav-link', { active: isActive(link.href) }]}
              >
                {link.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <a href="/download" class="btn btn--primary header-cta">Get the Mac app</a>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(28, 28, 30, 0.72);
    backdrop-filter: saturate(180%) blur(20px);
    -webkit-backdrop-filter: saturate(180%) blur(20px);
    border-bottom: 1px solid var(--border);
  }

  .header-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 60px;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.0625rem;
    letter-spacing: -0.01em;
  }
  .brand:hover {
    color: var(--text);
  }
  .brand-mark {
    width: 26px;
    height: 26px;
    border-radius: 7px;
  }

  nav {
    margin-left: auto;
  }
  .nav-list {
    display: flex;
    gap: 1.5rem;
    list-style: none;
    padding: 0;
  }
  .nav-link {
    color: var(--text-muted);
    font-size: 0.9375rem;
    font-weight: 500;
  }
  .nav-link:hover,
  .nav-link.active {
    color: var(--text);
  }

  .header-cta {
    padding: 0.5rem 1rem;
    font-size: 0.9375rem;
  }

  /* Simple responsive collapse: hide secondary nav on small screens.
     TODO: add a real mobile menu if needed. */
  @media (max-width: 760px) {
    .nav-list {
      display: none;
    }
    nav {
      margin-left: auto;
    }
  }
  @media (max-width: 460px) {
    .header-cta {
      display: none;
    }
  }
</style>
