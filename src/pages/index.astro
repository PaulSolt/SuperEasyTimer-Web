---
import BaseLayout from '../layouts/BaseLayout.astro';
import DownloadCTA from '../components/DownloadCTA.astro';
import StoreBadge from '../components/StoreBadge.astro';
import { site } from '../config/site';

// Which screenshot set the homepage uses. Swap to '/media/screenshots' to
// compare against the original set with the headline text baked in.
const SHOTS = '/media/screenshots-clean';

// Long-form sales sections. One feature per row, single column, no grids.
const sections = [
  {
    head: 'No fiddling. Just type.',
    body: 'Skip the dials and scroll wheels. Type "5 min", "20 minutes", "2h 30m", or "25" and press Return. Need a countdown to a clock time? Type "5pm". Add time as you go with "Add 5 min" without restarting.',
    img: `${SHOTS}/just-type.jpg`,
    alt: 'Typing "25 minutes" into Super Easy Timer to start a countdown.',
  },
  {
    head: 'Keep the countdown visible',
    body: 'Keep it in the menu bar so the time sits at the top of your screen, or tuck it into a corner while you work. The timer gets out of the way and stays glanceable. Control it from any app with global keyboard shortcuts.',
    img: `${SHOTS}/keep-visible.jpg`,
    alt: 'Super Easy Timer in the macOS menu bar with floating and full screen options.',
  },
  {
    head: 'A timer that floats on top',
    body: 'Float the timer over every app and keep it in view while you work and switch windows. It stays on top of full screen apps and presentations too, including Keynote, PowerPoint, and Zoom, without stealing focus.',
    img: `${SHOTS}/always-on-top.jpg`,
    alt: 'Super Easy Timer floating on top of a full screen app.',
  },
  {
    head: 'Show how much time is left',
    body: 'Make it a full screen countdown everyone in the room can read. Clear digits, no clutter. Built for classes, talks, meetings, webinars, and shared screens.',
    img: `${SHOTS}/full-screen.jpg`,
    alt: 'A large full screen countdown timer reading 25:00.',
  },
  {
    head: 'Make the timer yours',
    body: 'Pick from transparent, frosted, Liquid Glass, blue, red, black, white, and cream. Controls and the text input fade away while you work, then come back when you need them.',
    img: `${SHOTS}/themes.jpg`,
    alt: 'The theme picker showing transparent, frosted, Liquid Glass, and color themes.',
  },
  {
    head: 'Repeat timers, count up, and alarms',
    body: 'Set repeat timers with an optional delay for breaks, routines, and sessions. Count up after zero to see how far overtime you are. Restart automatically, flash the timer, and choose how many times the alarm repeats.',
    img: `${SHOTS}/repeat.jpg`,
    alt: 'End-of-timer options: flash the time, count up, and restart automatically with a delay.',
  },
];
---

<BaseLayout title={site.name} description={site.description}>
  <!-- Hero: the video sells the app, so it comes first -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-video">
        <video
          src="/media/app-preview.mp4"
          poster="/media/app-preview-poster.jpg"
          autoplay
          muted
          loop
          playsinline
          preload="auto"
          aria-label="Super Easy Timer app preview"
        ></video>
      </div>

      <h1>A timer that stays on top of every window.</h1>
      <p class="lead mx-auto">
        Keep it visible while you work, present it full screen, or read the
        countdown from across the room.
      </p>

      <div class="hero-cta">
        <StoreBadge height={52} />
      </div>

      <a class="hero-proof" href={site.macAppStoreUrl} rel="noopener" target="_blank">
        <strong>{site.rating}</strong><span class="star" aria-hidden="true">★</span>
        on the Mac App Store
      </a>

      <p class="hero-alt">
        <a href="/download">Other download options</a>
        <span class="dot">·</span>
        <a href="/timer">Try the free web timer</a>
      </p>
    </div>
  </section>

  <!-- Long-form feature sections, one per row -->
  {
    sections.map((s, i) => (
      <section class:list={['section', 'feature', { 'feature--alt': i % 2 === 1 }]}>
        <div class="container narrow text-center">
          <h2>{s.head}</h2>
          <p class="lead mx-auto">{s.body}</p>
          <figure class="shot">
            <img src={s.img} alt={s.alt} width="1600" height="739" loading="lazy" />
          </figure>
        </div>
      </section>
    ))
  }

  <!-- Who it's for -->
  <section class="section feature--alt">
    <div class="container narrow text-center">
      <h2>Made for people who need timers</h2>
      <p class="lead mx-auto">
        Speakers and teachers keep their talk on time. Focus sessions stay on
        track. Meetings and standups end when they should. Workouts, cooking, and
        routines get a simple repeat timer. One timer, every place you need to see
        the time.
      </p>
    </div>
  </section>

  <!-- Personal note from the maker -->
  <section class="section maker-note">
    <div class="container maker-inner">
      <img class="maker-photo" src="/media/paul.png" alt="Paul Solt" width="96" height="96" />
      <h2>Why I made this</h2>
      <div class="maker-body">
        <p>Hi, I'm Paul.</p>
        <p>
          Some days I look up and wonder where the time went. That is why I made
          Super Easy Timer. The other timers I tried were clunky, or they crashed
          right when I needed them. I wanted one that starts fast, stays on
          screen, and gets out of the way while I work.
        </p>
        <p>
          I use it every day. To stay focused. To catch a meeting. To leave on
          time to pick up my daughter. For years I wanted a timer that stays
          visible over full screen apps. That took a long time to get right. Now
          it just works.
        </p>
        <p>
          I built it for myself, and I keep making it better so it works for you
          too. It is free right now. I hope it helps you be more productive and
          stay on time.
        </p>
      </div>
      <img
        class="maker-signature"
        src="/media/paul-signature.png"
        alt="Paul Solt"
        width="180"
        height="76"
      />
      <p class="maker-name">Paul Solt, maker of Super Easy Timer</p>
    </div>
  </section>

  <!-- Social proof: real Mac App Store reviews -->
  <section class="section reviews-section">
    <div class="container">
      <div class="reviews-head text-center">
        <p class="rating-badge"><strong>{site.rating}</strong><span class="star" aria-hidden="true">★</span></p>
        <h2>Loved by Mac users</h2>
        <p class="lead mx-auto">Here is what people say on the Mac App Store.</p>
      </div>
      <ul class="reviews-grid">
        {
          site.reviews.map((r) => (
            <li class="review card">
              <p class="review-stars" aria-label="5 out of 5 stars">★★★★★</p>
              <blockquote class="review-quote">{r.quote}</blockquote>
              <p class="review-author">{r.author}</p>
            </li>
          ))
        }
      </ul>
      <p class="reviews-link text-center">
        <a href={site.macAppStoreUrl} rel="noopener" target="_blank">Read more reviews on the Mac App Store →</a>
      </p>
    </div>
  </section>

  <!-- Download CTA -->
  <section class="section">
    <div class="container">
      <DownloadCTA />
    </div>
  </section>
</BaseLayout>

<script>
  // Nudge muted autoplay (some browsers need the property set in JS, and only
  // start once the element is on screen).
  document.querySelectorAll<HTMLVideoElement>('video[autoplay]').forEach((v) => {
    v.muted = true;
    const play = () => v.play().catch(() => {});
    play();
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) play();
      });
    });
    io.observe(v);
  });
</script>

<style>
  .hero {
    padding-block: clamp(1.5rem, 3vw, 2.5rem) clamp(2rem, 4vw, 3rem);
    text-align: center;
    background:
      radial-gradient(60% 50% at 50% 0%, rgba(10, 132, 255, 0.18), transparent 70%),
      var(--bg);
  }
  .hero-inner {
    max-width: 860px;
  }

  /* Video is the hero. */
  .hero-video {
    margin: 0 auto 2rem;
    max-width: 860px;
    border-radius: var(--radius-card);
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-card);
    background: #000;
    aspect-ratio: 16 / 9;
  }
  .hero-video video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .hero h1 {
    font-size: clamp(2rem, 4.5vw, 3.25rem);
    max-width: 16ch;
    margin-inline: auto;
  }
  .hero .lead {
    margin-top: 0.875rem;
    max-width: 48ch;
  }

  .hero-cta {
    margin-top: 1.5rem;
  }

  .hero-proof {
    display: block;
    margin-top: 0.875rem;
    font-size: 0.9375rem;
    color: var(--text-faint);
  }
  .hero-proof:hover {
    color: var(--text-muted);
  }
  .hero-proof .star {
    color: #ffb800;
    margin-left: 2px;
    margin-right: 3px;
  }
  .hero-proof strong {
    color: var(--text);
  }

  .hero-alt {
    margin-top: 1rem;
    font-size: 0.875rem;
    color: var(--text-faint);
  }
  .hero-alt a {
    color: var(--text-muted);
  }
  .hero-alt a:hover {
    color: var(--text);
  }
  .hero-alt .dot {
    margin-inline: 0.5rem;
    opacity: 0.5;
  }

  /* Shared long-form layout: single, centered column. */
  .narrow {
    max-width: 760px;
  }
  .feature .lead {
    margin-top: 1rem;
  }
  .feature--alt {
    background: #161618;
  }

  /* Framed screenshot. */
  .shot {
    margin: 2rem auto 0;
    max-width: 880px;
    border-radius: var(--radius-card);
    overflow: hidden;
    border: 1px solid var(--border);
    box-shadow: var(--shadow-card);
    background: #fff;
  }
  .shot img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Maker's note */
  .maker-inner {
    max-width: 640px;
    text-align: center;
  }
  .maker-photo {
    width: 96px;
    height: 96px;
    border-radius: 50%;
    margin: 0 auto 1rem;
    border: 2px solid var(--border-strong);
  }
  .maker-body {
    margin-top: 1rem;
    text-align: left;
  }
  .maker-body p {
    margin-bottom: 1rem;
    font-size: 1.0625rem;
    color: var(--text-muted);
  }
  .maker-signature {
    width: 160px;
    height: auto;
    margin: 1.5rem 0 0.5rem;
  }
  .maker-name {
    font-size: 0.875rem;
    color: var(--text-faint);
  }

  /* Reviews / social proof */
  .reviews-section {
    background: #161618;
  }
  .reviews-head {
    max-width: 40ch;
    margin: 0 auto 2.5rem;
  }
  .rating-badge {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text);
  }
  .rating-badge .star {
    color: #ffb800;
    margin-left: 4px;
  }
  .reviews-head h2 {
    margin-top: 0.5rem;
  }
  .reviews-grid {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
    max-width: 920px;
    margin-inline: auto;
  }
  .review {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .review-stars {
    color: #ffb800;
    letter-spacing: 0.1em;
    font-size: 0.9375rem;
  }
  .review-quote {
    margin: 0;
    color: var(--text);
    font-size: 1.0625rem;
    line-height: 1.5;
  }
  .review-author {
    margin: 0;
    font-size: 0.875rem;
    color: var(--text-faint);
  }
  .reviews-link {
    margin-top: 2rem;
    font-size: 0.9375rem;
  }

  @media (max-width: 640px) {
    .reviews-grid {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 560px) {
    .hero-alt .dot {
      display: block;
      height: 0;
      overflow: hidden;
    }
  }
</style>
