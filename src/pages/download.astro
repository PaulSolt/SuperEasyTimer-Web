---
import BaseLayout from '../layouts/BaseLayout.astro';
import StoreBadge from '../components/StoreBadge.astro';
import { site } from '../config/site';

const title = 'Download Super Easy Timer';
const description =
  'Download Super Easy Timer free on the Mac App Store, or try the TestFlight beta. A countdown timer that stays visible over full screen apps and presentations. Windows coming soon.';
---

<BaseLayout title={title} description={description}>
  <section class="dl-hero">
    <div class="container">
      <p class="eyebrow">Download</p>
      <h1>Get Super Easy Timer.</h1>
      <p class="lead mx-auto">
        Free on Mac. A countdown timer that stays visible over full screen apps
        and presentations, including Keynote and PowerPoint.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container dl-grid">
      <!-- Mac -->
      <article class="card dl-card">
        <span class="dl-platform">macOS</span>
        <h2>Mac</h2>
        <p>Available now on the Mac App Store. Free.</p>
        <StoreBadge height={52} />
        <a class="btn btn--secondary" href={site.testFlightUrl} rel="noopener" target="_blank">
          Download the beta
        </a>
        <p class="dl-fine">
          Requires macOS {site.minMacOS} or later. The beta uses the free
          TestFlight app.
        </p>
      </article>

      <!-- Windows -->
      <article class="card dl-card dl-card--soon">
        <span class="dl-platform">Windows</span>
        <h2>Windows</h2>
        <p>Coming soon. Same timer, same always on top overlay, built for Windows.</p>
        {
          site.windowsDownloadUrl ? (
            <a class="btn btn--primary" href={site.windowsDownloadUrl} rel="noopener" target="_blank">
              Download for Windows
            </a>
          ) : (
            <span class="btn btn--secondary dl-disabled" aria-disabled="true">Coming soon</span>
          )
        }
      </article>
    </div>

    <div class="container dl-back">
      <p>
        Not ready to install? <a href="/timer">Try the timer for free on the web</a>.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .dl-hero {
    padding-block: clamp(2rem, 4vw, 3rem);
    text-align: center;
    background:
      radial-gradient(55% 45% at 50% 0%, rgba(10, 132, 255, 0.16), transparent 70%),
      var(--bg);
  }
  .dl-hero .lead {
    margin-top: 1rem;
    max-width: 50ch;
  }
  .dl-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    max-width: 880px;
    margin-inline: auto;
    align-items: start;
  }
  .dl-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 2rem;
  }
  .dl-platform {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--blue);
  }
  .dl-card h2 {
    font-size: 1.75rem;
  }
  .dl-card .btn {
    margin-top: 0.25rem;
    align-self: stretch;
  }
  .dl-card--soon {
    opacity: 0.92;
  }
  .dl-disabled {
    cursor: default;
    opacity: 0.6;
  }
  .dl-fine {
    font-size: 0.8125rem;
    color: var(--text-faint);
  }
  .dl-back {
    margin-top: 2.5rem;
    text-align: center;
  }
  @media (max-width: 720px) {
    .dl-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
