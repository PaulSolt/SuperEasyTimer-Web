---
import BaseLayout from '../layouts/BaseLayout.astro';
import Timer from '../components/Timer.astro';
import DownloadCTA from '../components/DownloadCTA.astro';
import { site } from '../config/site';

const title = 'Free online timer';
const description =
  'A free, full screen online timer. Type a time in plain language, press Return, and go. No sign-up, no ads. Works in any browser.';
---

<BaseLayout title={title} description={description}>
  <section class="tool-hero">
    <div class="container tool-hero-inner">
      <!-- Static, indexable heading + copy (timer logic hydrates below). -->
      <p class="eyebrow">Free Full Screen Timer</p>
      <h1>Simple Timer</h1>
      <p class="lead mx-auto">Type a time and start it.</p>

      <div class="tool-timer">
        <Timer initialMinutes={5} size="full" showFullscreen={true} />
      </div>
    </div>
  </section>

  <!-- Upsell: why the Mac app beats the web version -->
  <section class="section section--light">
    <div class="container upsell">
      <h2>The Mac app does more</h2>
      <div class="upsell-video">
        <video
          src="/media/app-preview.mp4"
          poster="/media/app-preview-poster.jpg"
          autoplay
          muted
          loop
          playsinline
          preload="auto"
          aria-label="Super Easy Timer app preview"
        ></video>
      </div>
      <p>
        The web timer is a good starter. It runs in your browser, on this page.
        The Mac app lifts the timer off the page and onto your whole screen.
      </p>
      <ul class="upsell-list">
        <li><strong>Move it anywhere:</strong> drag the timer to any corner of your screen.</li>
        <li><strong>Pin it on top:</strong> keep it above your other windows while you work.</li>
        <li><strong>Stay visible over full screen apps:</strong> see it over Keynote, PowerPoint, and Zoom, even in full screen.</li>
        <li><strong>Make it yours:</strong> transparent, frosted, Liquid Glass, and more, plus repeat timers and count up after zero.</li>
        <li><strong>Keep it in the menu bar:</strong> the countdown sits right at the top of your screen.</li>
      </ul>
      <div class="upsell-actions">
        <a
          class="btn btn--primary"
          href={site.macAppStoreUrl}
          rel="noopener"
          target="_blank"
          data-ga="download_intent"
          data-ga-platform="mac_app_store"
          data-ga-location="timer_upsell"
        >
          Get the free Mac app
        </a>
        <span class="upsell-fine">Free. macOS {site.minMacOS}+. Windows soon.</span>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container tool-info">
      <h2>How to use the web timer</h2>
      <ul>
        <li><strong>Set a time:</strong> type "10 minutes", "10 m", "1:30", or "90s", then press Return.</li>
        <li><strong>Count down to a clock time:</strong> type "5pm" or "2:15am" (add am or pm so it is read as a time, not a duration).</li>
        <li><strong>Add or remove time:</strong> type "add 5 min", "+5m", or "-1h" to adjust without restarting.</li>
        <li><strong>Start or pause:</strong> click the pill or use the Start button.</li>
        <li><strong>Theme:</strong> switch between blue and black with the swatches. Your choice is remembered.</li>
        <li><strong>Full screen:</strong> use the Full screen button for a distraction-free countdown that keeps your theme.</li>
        <li><strong>Sound:</strong> a gentle tone plays when the timer finishes, after your first click.</li>
      </ul>

      <DownloadCTA location="timer_bottom" />
    </div>
  </section>
</BaseLayout>

<script>
  // Nudge muted autoplay for the preview video.
  document.querySelectorAll<HTMLVideoElement>('video[autoplay]').forEach((v) => {
    v.muted = true;
    v.play().catch(() => {});
  });
</script>

<style>
  .tool-hero {
    padding-block: clamp(1.25rem, 3vw, 2.25rem);
    text-align: center;
    background:
      radial-gradient(55% 45% at 50% 0%, rgba(10, 132, 255, 0.18), transparent 70%),
      var(--bg);
  }
  .tool-hero-inner {
    max-width: 680px;
  }
  .tool-hero .lead {
    margin-top: 0.625rem;
    max-width: 46ch;
  }
  .tool-timer {
    margin-top: 1.75rem;
  }
  .tool-info {
    max-width: var(--content-width);
  }
  .tool-info ul {
    margin: 1.25rem 0 2.5rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    color: var(--text-muted);
  }
  .tool-info strong {
    color: var(--text);
  }

  .upsell {
    max-width: var(--content-width);
  }
  .upsell-video {
    margin: 0 0 1.5rem;
    border-radius: var(--radius-card);
    overflow: hidden;
    border: 1px solid rgba(0, 0, 0, 0.1);
    box-shadow: var(--shadow-card);
    background: #000;
    aspect-ratio: 16 / 9;
  }
  .upsell-video video {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .upsell h2 {
    margin-bottom: 1rem;
  }
  .upsell > p {
    font-size: 1.0625rem;
    margin-bottom: 1.25rem;
  }
  .upsell-list {
    margin: 0 0 1.75rem 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    font-size: 1.0625rem;
    color: var(--light-text-muted);
  }
  .upsell-list strong {
    color: var(--light-text);
  }
  .upsell-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .upsell-fine {
    font-size: 0.875rem;
    color: var(--light-text-muted);
  }
</style>
