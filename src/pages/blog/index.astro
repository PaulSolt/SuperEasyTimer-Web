---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const title = 'Blog';
const description =
  'Guides on presentation timers, always-on-top utilities, focus, and meetings: how to keep time visible without leaving what you are doing.';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime()
);

const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' });
---

<BaseLayout title={title} description={description}>
  <section class="blog-hero">
    <div class="container">
      <p class="eyebrow">Blog</p>
      <h1>Timing, presentations, and staying on top.</h1>
      <p class="lead">
        Practical guides on keeping a timer visible while you present, focus, and
        run meetings.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {
        posts.length === 0 ? (
          <p>No posts yet. Check back soon.</p>
        ) : (
          <ul class="post-list">
            {posts.map((post) => (
              <li class="post-item">
                <a href={`/blog/${post.id}`} class="post-card card">
                  {post.data.heroImage && (
                    <span class="post-card-thumb">
                      <img
                        src={post.data.heroImage}
                        alt={post.data.heroAlt ?? post.data.title}
                        width="1600"
                        height="1000"
                        loading="lazy"
                      />
                    </span>
                  )}
                  <p class="post-cluster">{post.data.cluster}</p>
                  <h2 class="post-card-title">{post.data.title}</h2>
                  <p class="post-card-desc">{post.data.description}</p>
                  <time class="post-card-date" datetime={post.data.publishDate.toISOString()}>
                    {fmt(post.data.publishDate)}
                  </time>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>
  </section>
</BaseLayout>

<style>
  .blog-hero {
    padding-block: clamp(2.5rem, 6vw, 4rem);
  }
  .blog-hero .lead {
    margin-top: 1rem;
  }
  .post-list {
    list-style: none;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  .post-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    height: 100%;
    padding: 0;
    overflow: hidden;
    transition: border-color 0.15s ease, transform 0.1s ease;
  }
  .post-card:hover {
    border-color: var(--border-strong);
    transform: translateY(-2px);
  }
  .post-card-thumb {
    display: block;
    background: #fff;
    border-bottom: 1px solid var(--border);
  }
  .post-card-thumb img {
    display: block;
    width: 100%;
    height: auto;
  }
  .post-card > :not(.post-card-thumb) {
    margin-inline: 1.5rem;
  }
  .post-card > .post-cluster {
    margin-top: 1.25rem;
  }
  .post-card-date {
    margin-bottom: 1.5rem;
  }
  .post-cluster {
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--blue);
  }
  .post-card-title {
    font-size: 1.25rem;
    color: var(--text);
  }
  .post-card-desc {
    font-size: 0.9375rem;
    flex: 1;
  }
  .post-card-date {
    font-size: 0.8125rem;
    color: var(--text-faint);
  }
  @media (max-width: 720px) {
    .post-list {
      grid-template-columns: 1fr;
    }
  }
</style>
