---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page not found" description="That page does not exist." noindex={true}>
  <section class="nf">
    <div class="container">
      <p class="eyebrow">404</p>
      <h1>That page ran out of time.</h1>
      <p class="lead mx-auto">
        The page you are looking for does not exist. Try one of these instead.
      </p>
      <div class="nf-actions">
        <a class="btn btn--primary" href="/">Home</a>
        <a class="btn btn--secondary" href="/timer">Web timer</a>
        <a class="btn btn--ghost" href="/blog">Blog</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .nf {
    padding-block: clamp(4rem, 12vw, 8rem);
    text-align: center;
  }
  .nf .lead {
    margin-top: 1rem;
    max-width: 40ch;
  }
  .nf-actions {
    margin-top: 2rem;
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    flex-wrap: wrap;
  }
</style>
